---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Not Found">
    <h1 class="mt-5 ml-5">404</h1>
    <h2 class="text-center">Page introuvable</h2>
    <img src="/src/assets/icons/recherche.svg" alt="Image d'erreur 404" style="width: 200px; height: auto; margin: 20px auto; display: block;" />
    <p class="text-center">Oups ! La page que vous recherchez semble s'être envolée avec nos drones. Elle n'existe pas ou a été déplacée.</p>
<div class="flex justify-center items-center mt-4">
    <a href="/" class="flex items-center justify-center gap-2 px-6 py-2 rounded-full bg-[#070B1A] text-white text-base border border-blue-700 shadow-[0_0_18px_rgba(29,78,216,0.35)] hover:shadow-[0_0_28px_rgba(29,78,216,0.6)] transition">
        <img src="/src/assets/icons/home.svg" class="w-5 h-5" alt="Home">
        Retour à l'accueil
    </a>
</div>
<div class=" flex justify-center items-center mr-3 gap-3 mt-4">
    <img class="inline align-middle" src="/src/assets/icons/rondbleu.svg"> 
    <img class="inline align-middle"  src="/src/assets/icons/rondrose.svg"> 
    <img class="inline align-middle" src="/src/assets/icons/rondturquoise.svg">
</div>