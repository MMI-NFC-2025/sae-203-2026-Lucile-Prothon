---
import Layout from "../layouts/Layout.astro";
import Recherche from "../assets/icons/recherche.svg";
import RondTurquoise from "../assets/icons/rondturquoise.svg";
import RondBleu from "../assets/icons/rondbleu.svg";
import RondRose from "../assets/icons/rondrose.svg";
import Home from "../assets/icons/home.svg";
---

<Layout title="Not Found">
    <h1 class="mt-5 ml-5">404</h1>
    <h2 class="text-center">Page introuvable</h2>
    <Recherche
        alt="Image d'erreur 404"
        style="width: 200px; height: auto; margin: 20px auto; display: block;"
    />
    <p class="text-center">
        Oups ! La page que vous recherchez semble s'être envolée avec nos
        drones. Elle n'existe pas ou a été déplacée.
    </p>
    <div class="flex justify-center items-center mt-4">
        <a
            href="/"
            class="flex items-center justify-center gap-2 px-6 py-2 rounded-full bg-[#070B1A] text-white text-base border border-blue-700 shadow-[0_0_18px_rgba(29,78,216,0.35)] hover:shadow-[0_0_28px_rgba(29,78,216,0.6)] transition"
        >
            <Home class="w-5 h-5" alt="Home" />
            Retour à l'accueil
        </a>
    </div>
    <div class="flex justify-center items-center mr-3 gap-3 mt-4">
        <RondBleu class="inline align-middle">
            <RondRose class="inline align-middle">
                <RondTurquoise class="inline align-middle" />
                
            
        
    </div></Layout
>
