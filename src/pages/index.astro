---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import { Image } from "astro:assets";
import TapTech from "../assets/img/taptechfusion.avif";
import Chaussure from "../assets/img/chaussure.avif";
import Info from "../assets/img/info-programme.avif";
import Bourgogne from "../assets/img/logo_bourgogne-franche-comté1.avif";
import Tourisme from "../assets/img/logo_tourisme1.avif";
import Montbeliard from "../assets/img/montbeliard.avif";
import Doubs from "../assets/img/logo-doubs1.avif";
import Calendrier from "../assets/icons/calendrier.svg";
import Lieu from "../assets/icons/lieu.svg";
import Billet from "../assets/icons/billet.svg";
import CalendrierBleu from "../assets/icons/calendrierbleu.svg";
import FlecheGaucheBleu from "../assets/icons/flèchegauchebleu.svg";
import FlecheGaucheRose from "../assets/icons/flèchegaucherose.svg";
import Artiste from "../assets/icons/artiste.svg";
---

<Layout title="Scènes">
	<Hero />
	<div class="flex items-center pl-20 mt-5">
		<h1 class="text_degrede">FlyTapFest</h1>
		<Image
			src={Chaussure}
			alt="Image d'exemple d'un spectacle de drone"
			style="width: 600px; height: auto; margin-left: auto; margin-right: 0;"
		/>
	</div>
	<h2 class="text-brandingblue">Festival de claquettes</h2>
	<p>
		Fusion entre claquettes traditionnelles et spectacle de drones lumineux
	</p>
	<div class="text-right pr-6">
		<p class="font-bold text-2xl">
			<Calendrier
				class="inline align-middle mr-3 font-semibold"
				alt="Calendrier"
				>6-7 juin 2026
			</Calendrier>
			<p class="text-grey-4">
				<Lieu class="inline align-middle mr-3" alt="Localisation" /> Parc
				du Près-la-Rose, Montbéliard
			</p>
		</p>
		<div class="flex justify-left items-center mt-4">
			<a
				href="/404.astro"
				class="flex items-center justify-center gap-2 px-6 py-2 rounded-full bg-[#070B1A] text-white text-base border border-blue-700 shadow-[0_0_18px_rgba(29,78,216,0.35)] hover:shadow-[0_0_28px_rgba(29,78,216,0.6)] transition"
			>
				<Billet class="w-5 h-5" alt="Billetterie" />
				Réserver mes billets
			</a>
		</div>
		<h3 class="2xl text-white font-bold">
			Un festival entre ciel et terre
		</h3>
		<p class="base text-grey-4 font-bold">
			Le FlyTapFest est un événement unique qui marie l'art ancestral des
			claquettes avec la technologie moderne des drones lumineux pour
			créer un spectacle époustouflant.
		</p>
		<div class="flex justify-left items-center mt-4">
			<a
				href="/festival"
				class="flex items-center justify-center gap-2 px-6 py-2 rounded-full bg-[#070B1A] text-white text-base border border-blue-700 shadow-[0_0_18px_rgba(29,78,216,0.35)] hover:shadow-[0_0_28px_rgba(29,78,216,0.6)] transition"
			>
				En savoir plus</a
			>
		</div>
		<h4 class="2xl text-white font-bold">Découvrir le festival</h4>
		<div class="grille">
			<div class="lg:col-span-3">
				<Image
					src={Info}
					alt="Décoration programme"
					class="mt-4 border-4 border-blue-700 rounded-lg w-64 h-64 object-cover overflow-hidden"
				/>
				<div class="flex justify-left items-center mt-4">
					<a
						href="/programme"
						class="flex items-center justify-center gap-2 px-6 py-2 rounded-full bg-[#070B1A] text-white text-base border border-blue-700 shadow-[0_0_18px_rgba(29,78,216,0.35)] hover:shadow-[0_0_28px_rgba(29,78,216,0.6)] transition"
					>
						<CalendrierBleu alt="calendrier" class="w-5 h-5" /> Programme
						<FlecheGaucheBleu alt="Flèche droite" class="w-5 h-5" />
					</a>
				</div>
				<div class="lg:col-span-3">
					<Image
						src={Info}
						alt="Décoration programme"
						class="mt-4 border-4 border-neonpink rounded-lg w-64 h-64 object-cover overflow-hidden"
					/>
					<div class="flex justify-left items-center mt-4">
						<a
							href="/scenes"
							class="flex items-center justify-center gap-2 px-6 py-2 rounded-full bg-[#070B1A] text-white text-base border border-neonpink shadow-[0_0_18px_rgba(29,78,216,0.35)] hover:shadow-[0_0_28px_rgba(29,78,216,0.6)] transition"
						>
							<Lieu alt="lieu" class="w-5 h-5" /> Scènes <FlecheGaucheRose
								alt="Flèche droite"
								class="w-5 h-5"
							/></a
						>
					</div>
				</div>
				<div class="lg:col-span-3">
					<Image
						src={TapTech}
						alt="Décoration programme"
						class="mt-4 border-4 border-neonpurple rounded-lg w-64 h-64 object-cover overflow-hidden"
					/>
					<div class="flex justify-left items-center mt-4">
						<a
							href="/artiste"
							class="flex items-center justify-center gap-2 px-6 py-2 rounded-full bg-[#070B1A] text-white text-base border border-neonpurple shadow-[0_0_18px_rgba(29,78,216,0.35)] hover:shadow-[0_0_28px_rgba(29,78,216,0.6)] transition"
						>
							<Artiste alt="artiste" class="w-5 h-5" /> Artistes <img
								src="/src/assets/icons/flèchegaucheviolet.svg"
								alt="Flèche droite"
								class="w-5 h-5"
							/></a
						>
					</div>
				</div>
			</div>
			<Image
				src={TapTech}
				alt="Décoration scène"
				class="mt-20 rounded-lg w-full"
			/>
			<h5 class="2xl text-white font-bold">Nos partenaires</h5>
			<div class="grille">
				<div class="lg:col-span-3">
					<Image
						src={Doubs}
						alt="Partenaire 1"
						class="mt-4 border-2 border-grey-3 bg-grey-4 rounded-lg object-cover overflow-hidden"
					/>
					<p class="font-semibold mt-4">Département du Doubs</p>
				</div>
				<div class="lg:col-span-3">
					<Image
						src={Montbeliard}
						alt="Partenaire 1"
						class="mt-4 border-2 border-grey-3 bg-grey-4 rounded-lg object-cover overflow-hidden"
					/>
					<p class="font-semibold mt-4">Ville de Montbéliard</p>
				</div>
				<div class="lg:col-span-3">
					<Image
						src={Tourisme}
						alt="Partenaire 1"
						class="mt-4 border-2 border-grey-3 bg-grey-4 rounded-lg object-cover overflow-hidden"
					/>
					<p class="font-semibold mt-4">Office de Tourisme</p>
				</div>
				<div class="lg:col-span-3">
					<Image
						src={Bourgogne}
						alt="Partenaire 1"
						class="mt-4 border-2 border-grey-3 bg-grey-4 rounded-lg object-cover overflow-hidden"
					/>
					<p class="font-semibold mt-4">
						Région Bourgogne-Franche Comté
					</p>
				</div>
			</div>
		</div>
	</div>
</Layout>
