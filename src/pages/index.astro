---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import { Image } from "astro:assets";
---

<Layout>
	<Hero />
	<div class="flex items-center pl-20 mt-5">
		<h1 class="text_degrede">FlyTapFest</h1>
		<Image
			src="src/assets/img/chaussure.avif"
			alt="Image d'exemple d'un spectacle de drone"
			style="width: 600px; height: auto; margin-left: auto; margin-right: 0;"
		/>
	</div>
	<h2 class="text-darkblue">Festival de claquettes</h2>
	<p>Fusion entre claquettes traditionnelles et spectacle de drones lumineux</p>
	<div class="text-right pr-6">
		<p class="font-bold">
			<img
				class="inline align-middle mr-3 font-semibold"
				src="/src/assets/icons/calendrier.svg"
				alt="Calendrier"
			/>6-7 juin 2026
		</p>
		<p class="text-grey-4">
			<img
				class="inline align-middle mr-3"
				src="/src/assets/icons/lieu.svg"
				alt="Localisation"
			/> Parc du Près-la-Rose, Montbéliard
		</p>
	</div>
<div class="flex justify-left items-center mt-4">
    <a href="/404.astro" class="flex items-center justify-center gap-2 px-6 py-2 rounded-full bg-[#070B1A] text-white text-base border border-blue-700 shadow-[0_0_18px_rgba(29,78,216,0.35)] hover:shadow-[0_0_28px_rgba(29,78,216,0.6)] transition">
        <img src="/src/assets/icons/billet.svg" class="w-5 h-5" alt="Billetterie">
        Réserver mes billets
    </a>
</div>
<h3 class="2xl text-white font-bold">Un festival entre ciel et terre</h2>
<p class="base text-grey-4 font-bold">Le FlyTapFest est un événement unique qui marie l'art ancestral des claquettes avec la technologie moderne des drones lumineux pour créer un spectacle époustouflant.</p>
<div class="flex justify-left items-center mt-4">
    <a href="/festival.astro" class="flex items-center justify-center gap-2 px-6 py-2 rounded-full bg-[#070B1A] text-white text-base border border-blue-700 shadow-[0_0_18px_rgba(29,78,216,0.35)] hover:shadow-[0_0_28px_rgba(29,78,216,0.6)] transition">
        En savoir plus</a>
</div>
</Layout>
