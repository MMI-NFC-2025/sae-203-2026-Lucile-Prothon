---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import { Image } from "astro:assets";
---

<Layout title="Scènes">
	<Hero />
	<div class="flex items-center pl-20 mt-5">
		<h1 class="text_degrede">FlyTapFest</h1>
		<Image
			src="src/assets/img/chaussure.avif"
			alt="Image d'exemple d'un spectacle de drone"
			style="width: 600px; height: auto; margin-left: auto; margin-right: 0;"
		/>
	</div>
	<h2 class="text-brandingblue">Festival de claquettes</h2>
	<p>
		Fusion entre claquettes traditionnelles et spectacle de drones lumineux
	</p>
	<div class="text-right pr-6">
		<p class="font-bold text-2xl">
			<img
				class="inline align-middle mr-3 font-semibold"
				src="/src/assets/icons/calendrier.svg"
				alt="Calendrier"
			/>6-7 juin 2026
		</p>
		<p class="text-grey-4">
			<img
				class="inline align-middle mr-3"
				src="/src/assets/icons/lieu.svg"
				alt="Localisation"
			/> Parc du Près-la-Rose, Montbéliard
		</p>
	</div>
	<div class="flex justify-left items-center mt-4">
		<a
			href="/404.astro"
			class="flex items-center justify-center gap-2 px-6 py-2 rounded-full bg-[#070B1A] text-white text-base border border-blue-700 shadow-[0_0_18px_rgba(29,78,216,0.35)] hover:shadow-[0_0_28px_rgba(29,78,216,0.6)] transition"
		>
			<img
				src="/src/assets/icons/billet.svg"
				class="w-5 h-5"
				alt="Billetterie"
			/>
			Réserver mes billets
		</a>
	</div>
	<h3 class="2xl text-white font-bold">Un festival entre ciel et terre</h3>
	<p class="base text-grey-4 font-bold">
		Le FlyTapFest est un événement unique qui marie l'art ancestral des
		claquettes avec la technologie moderne des drones lumineux pour créer un
		spectacle époustouflant.
	</p>
	<div class="flex justify-left items-center mt-4">
		<a
			href="/festival"
			class="flex items-center justify-center gap-2 px-6 py-2 rounded-full bg-[#070B1A] text-white text-base border border-blue-700 shadow-[0_0_18px_rgba(29,78,216,0.35)] hover:shadow-[0_0_28px_rgba(29,78,216,0.6)] transition"
		>
			En savoir plus</a
		>
	</div>
	<h4 class="2xl text-white font-bold">Découvrir le festival</h4>
	<div class="grille">
		<div class="lg:col-span-3">
			<img
				src="/src/assets/img/info-programme.avif"
				alt="Décoration programme"
				class="mt-4 border-4 border-blue-700 rounded-lg w-64 h-64 object-cover overflow-hidden"
			/>
			<div class="flex justify-left items-center mt-4">
				<a
					href="/programme"
					class="flex items-center justify-center gap-2 px-6 py-2 rounded-full bg-[#070B1A] text-white text-base border border-blue-700 shadow-[0_0_18px_rgba(29,78,216,0.35)] hover:shadow-[0_0_28px_rgba(29,78,216,0.6)] transition"
				>
					<img
						src="/src/assets/icons/calendrierbleu.svg"
						alt="calendrier"
						class="w-5 h-5"
					/> Programme <img
						src="/src/assets/icons/flèchegauchebleu.svg"
						alt="Flèche droite"
						class="w-5 h-5"
					/></a
				>
			</div>
		</div>
		<div class="lg:col-span-3">
			<img
				src="/src/assets/img/info-programme.avif"
				alt="Décoration programme"
				class="mt-4 border-4 border-neonpink rounded-lg w-64 h-64 object-cover overflow-hidden"
			/>
			<div class="flex justify-left items-center mt-4">
				<a
					href="/scènes"
					class="flex items-center justify-center gap-2 px-6 py-2 rounded-full bg-[#070B1A] text-white text-base border border-neonpink shadow-[0_0_18px_rgba(29,78,216,0.35)] hover:shadow-[0_0_28px_rgba(29,78,216,0.6)] transition"
				>
					<img
						src="/src/assets/icons/lieu.svg"
						alt="lieu"
						class="w-5 h-5"
					/> Scènes <img
						src="/src/assets/icons/flèchegaucherose.svg"
						alt="Flèche droite"
						class="w-5 h-5"
					/></a
				>
			</div>
		</div>
		<div class="lg:col-span-3">
			<img
				src="/src/assets/img/taptechfusion.avif"
				alt="Décoration programme"
				class="mt-4 border-4 border-neonpurple rounded-lg w-64 h-64 object-cover overflow-hidden"
			/>
			<div class="flex justify-left items-center mt-4">
				<a
					href="/artiste"
					class="flex items-center justify-center gap-2 px-6 py-2 rounded-full bg-[#070B1A] text-white text-base border border-neonpurple shadow-[0_0_18px_rgba(29,78,216,0.35)] hover:shadow-[0_0_28px_rgba(29,78,216,0.6)] transition"
				>
					<img
						src="/src/assets/icons/artiste.svg"
						alt="artiste"
						class="w-5 h-5"
					/> Artistes <img
						src="/src/assets/icons/flèchegaucheviolet.svg"
						alt="Flèche droite"
						class="w-5 h-5"
					/></a
				>
			</div>
		</div>
	</div>
	<img
		src="/src/assets/img/taptechfusion.avif"
		alt="Décoration scène"
		class="mt-20 rounded-lg w-full"
	/>
	<h5 class="2xl text-white font-bold">Nos partenaires</h5>
	<div class="grille">
		<div class="lg:col-span-3">
			<img
				src="/src/assets/img/logo-doubs1.avif"
				alt="Partenaire 1"
				class="mt-4 border-2 border-grey-3 bg-grey-4 rounded-lg object-cover overflow-hidden"
			/>
			<p class="font-semibold mt-4">Département du Doubs</p>
		</div>
		<div class="lg:col-span-3">
			<img
				src="/src/assets/img/montbeliard.avif"
				alt="Partenaire 1"
				class="mt-4 border-2 border-grey-3 bg-grey-4 rounded-lg object-cover overflow-hidden"
			/>
			<p class="font-semibold mt-4">Ville de Montbéliard</p>
		</div>
		<div class="lg:col-span-3">
			<img
				src="/src/assets/img/logo_tourisme1.avif"
				alt="Partenaire 1"
				class="mt-4 border-2 border-grey-3 bg-grey-4 rounded-lg object-cover overflow-hidden"
			/>
			<p class="font-semibold mt-4">Office de Tourisme</p>
		</div>
		<div class="lg:col-span-3">
			<img
				src="/src/assets/img/logo_bourgogne-franche-comté1.avif"
				alt="Partenaire 1"
				class="mt-4 border-2 border-grey-3 bg-grey-4 rounded-lg object-cover overflow-hidden"
			/>
			<p class="font-semibold mt-4">Région Bourgogne-Franche Comté</p>
		</div>
	</div>
</Layout>
