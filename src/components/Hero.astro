---
const { title, subTitle } = Astro.props;
---

<div>
    <div>
        <h1>{title}</h1>
        {
            subTitle && (
                <h2 class="font-sans text-sm font-bold uppercase lg:text-lg">
                    {subTitle}
                </h2>
            )
        }
    </div>
</div>
