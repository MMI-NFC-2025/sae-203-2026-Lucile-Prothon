---
import "../styles/global.css";

import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";

const { title, description, image = "src/assets/icons/logo.svg" } = Astro.props;

const baseUrl = "https://housemood.com";
const pageUrl = `${baseUrl}${Astro.url.pathname}`;
const siteName = "FlyTapFest";

const titleHead =
	Astro.url.pathname === "/" ? siteName : `${title} — ${siteName}`;
const imageUrl = image.startsWith("http") ? image : `${baseUrl}${image}`;
---

<!doctype html>
<html lang="fr">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link
			rel="icon"
			type="image/svg+xml"
			href="/src/assets/icons/logo.svg"
		/>
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>FlyTapFest</title>
	</head>
	<body>
		<Header />
		<slot />
		<Footer />
	</body>
</html>
